HOST=0.0.0.0
PORT=8000
IMIXING_HOST_PORT=80
IMIXING_ENV=production-demo
IMIXING_DATABASE_URL=sqlite:////data/imixing_app.db
IMIXING_JOB_ROOT=/data/jobs
IMIXING_STORAGE_BACKEND=local
IMIXING_STORAGE_ROOT=/data/storage
IMIXING_QUEUE_BACKEND=background
IMIXING_PUBLIC_BASE_URL=http://YOUR_BEGET_SERVER_IP

# Free demo tokens/credits for internet testing.
IMIXING_FREE_DEMO_CREDITS=25
IMIXING_MIDI_CREDIT_COST=1
IMIXING_AUDIO_CREDIT_COST=5
IMIXING_CREDIT_COOKIE=imixing_credit_session

# Conservative public demo limits for a small VPS.
IMIXING_MAX_AUDIO_UPLOAD_MB=100
IMIXING_MAX_AUDIO_STEMS=12
IMIXING_MAX_AUDIO_DURATION_SECONDS=180
IMIXING_MAX_MIDI_UPLOAD_MB=5

IMIXING_ANALYTICS_ENABLED=true
IMIXING_DEBUG=false
SENTRY_DSN=
