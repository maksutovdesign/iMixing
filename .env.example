HOST=127.0.0.1
PORT=8000
IMIXING_ENV=development
IMIXING_DATABASE_URL=sqlite:////tmp/imixing_app.db
IMIXING_JOB_ROOT=/tmp/imixing_jobs
IMIXING_STORAGE_BACKEND=local
IMIXING_STORAGE_ROOT=/tmp/imixing_storage
IMIXING_QUEUE_BACKEND=background
IMIXING_PUBLIC_BASE_URL=http://127.0.0.1:8000
IMIXING_MAX_AUDIO_UPLOAD_MB=250
IMIXING_MAX_AUDIO_STEMS=24
IMIXING_MAX_AUDIO_DURATION_SECONDS=600
IMIXING_MAX_MIDI_UPLOAD_MB=10
IMIXING_FREE_DEMO_CREDITS=5
IMIXING_MIDI_CREDIT_COST=1
IMIXING_AUDIO_CREDIT_COST=5
IMIXING_CREDIT_COOKIE=imixing_credit_session
IMIXING_AUTH_COOKIE=imixing_auth_session
IMIXING_AUTH_SESSION_DAYS=30
IMIXING_ANALYTICS_ENABLED=true
IMIXING_DEBUG=false
SENTRY_DSN=
# Future S3/R2 variables for the object-storage adapter:
# IMIXING_STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# IMIXING_STORAGE_REGION=auto
# IMIXING_STORAGE_BUCKET=
# IMIXING_STORAGE_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# Future queue variables:
# IMIXING_QUEUE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0
